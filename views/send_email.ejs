<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Form Page</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <style>
    body {
      font-family: Arial, sans-serif;
      background-color: #f4f4f4;
      margin: 0;
      padding: 0;
      display: flex;
      justify-content: center;
      align-items: center;
      height: 100vh;
    }
    .container {
      background-color: #fff;
      border-radius: 10px;
      box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
      padding: 30px;
      width: 300px;
    }
    button {
      padding: 10px 20px;
      background-color: #007bff;
      color: #fff;
      border: none;
      border-radius: 5px;
      cursor: pointer;
      transition: background-color 0.3s ease;
    }
    button:hover {
      background-color: #0056b3;
    }
    button i {
      margin-right: 5px;
    }
    .input-div {
    border: 2px solid;
    display: flex;
    align-items: center;
    padding: 9px;
    margin: 1.1rem 0;
    gap: 0.41rem;
    border-radius: 5px;
}
.input-div input {
    border: none;
    padding: 0;
    margin: 0;
    font-size: 1.1rem;
}
input:focus-visible {
    outline: none;
}
.btn-div {
    display: flex;
    justify-content: center;
}
  </style>
</head>
<body>
  <div class="container">
    <h2></h2>
    <form action="/user/sendOtp" method="post">
        <label for="">Enter your Email:</label>
        <div class="input-div">
            <i class="fas fa-user"></i>
            <input type="email" name="email" placeholder="Your Email" required>
        </div>
        <% if(typeof message != "undefined" && message){ %>
          <p><%=message %></p>
          <% } %>
    <div class="btn-div"><button type="submit"><i class="fas fa-paper-plane"></i> Send Otp</button></div>
    </form>
  </div>
</body>
</html>
